{
  "name": "@deeeed/metamask-recipe-runner",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "metamask-recipe": "bin/metamask-recipe"
  },
  "scripts": {
    "dev:link-farmslot": "node scripts/link-local-farmslot.mjs",
    "check": "node scripts/check.mjs",
    "self-test": "bin/metamask-recipe self-test",
    "manifest:mobile": "bin/metamask-recipe manifest --adapter mobile --json",
    "manifest:extension": "bin/metamask-recipe manifest --adapter extension --json",
    "check:syntax": "find . -name '*.mjs' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@farmslot/protocol": "^0.6.0",
    "@farmslot/recipe-harness": "^0.2.0",
    "tsx": "^4.19.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "main": "./recipe/src/index.ts",
  "types": "./recipe/src/index.ts",
  "exports": {
    ".": {
      "types": "./recipe/src/index.ts",
      "import": "./recipe/src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "scripts",
    "orchestration",
    "recipe",
    "recipes",
    "library",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "packageManager": "yarn@4.5.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abretonc7s/metamask-recipe-runner.git"
  },
  "bugs": {
    "url": "https://github.com/abretonc7s/metamask-recipe-runner/issues"
  },
  "homepage": "https://github.com/abretonc7s/metamask-recipe-runner#readme"
}
